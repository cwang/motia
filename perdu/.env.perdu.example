# Perdu Development Environment Variables Example
# Copy this file to .env.perdu.local and replace with your actual values

# PostgreSQL Configuration
PERDU_DB_HOST=localhost
PERDU_DB_PORT=5433
PERDU_DB_USER=motia
PERDU_DB_PASSWORD=motia_perdu

# Single Database Per Stage (Opinionated PostgreSQL-Only Approach)
# Database name is determined by PERDU_STAGE environment variable
PERDU_STAGE=dev
PERDU_DB_NAME=motia_perdu


# Perdu SDK Configuration
PERDU_APP_NAME=motia-perdu
PERDU_APP_VERSION=1.0.0